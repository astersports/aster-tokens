{
  "name": "@aster/tokens",
  "version": "0.3.1",
  "description": "Canonical Aster design tokens + type — one light palette and one type system for every Aster-branded surface. Values-only: no components, no runtime dependencies.",
  "type": "module",
  "license": "UNLICENSED",
  "private": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./tokens.css": "./tokens.css",
    "./typography.css": "./typography.css",
    "./css": "./tokens.css",
    "./surface-classes.json": "./surface-classes.json",
    "./tokens.js": "./tokens.js",
    "./typography.js": "./typography.js",
    "./consumer-guard": {
      "types": "./consumer-guard.d.ts",
      "import": "./consumer-guard.js"
    }
  },
  "types": "./index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "tokens.css",
    "tokens.js",
    "tokens.d.ts",
    "typography.css",
    "typography.js",
    "typography.d.ts",
    "surface-classes.json",
    "consumer-guard.js",
    "consumer-guard.d.ts",
    "scripts/drift-guard.mjs"
  ],
  "scripts": {
    "drift-guard": "node scripts/drift-guard.mjs",
    "test": "node --test scripts/consumer-guard.test.mjs"
  }
}
